# OpenS2P – Environment Configuration
# =====================================
# Copy this file to .env and adjust values for your environment.
#
#   cp .env.example .env

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=OpenS2P API
APP_VERSION=0.2.0
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opens2p:opens2p@localhost:5432/opens2p_dev

# ── Security ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=opens2p-dev-secret-key-do-not-use-in-production
JWT_EXPIRE_MINUTES=60

# ── AI / ML ────────────────────────────────────────────────────────────────
AI_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Observability ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=

# ── CORS ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
